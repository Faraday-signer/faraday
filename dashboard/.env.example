# Copy this file to `.env` and fill in the value. `.env` is gitignored.
#
# Vite exposes VITE_* env vars to the bundle at build time, meaning the
# value ends up in the shipped JS and is publicly readable. Only put
# values that are safe to be public here.

# Solana mainnet RPC URL. If unset, falls back to the public Solana RPC
# (https://api.mainnet-beta.solana.com), which heavily rate-limits and
# blocks getProgramAccounts on Squads — account discovery won't work.
# Recommended: a Helius/QuickNode/Triton URL with a domain-restricted
# or quota-limited key.
VITE_RPC_URL=
