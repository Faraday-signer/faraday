# Copy this file to `.env` and fill in the values. `.env` is gitignored.
#
# Vite/WXT exposes VITE_* env vars to the extension bundle at build time,
# meaning they end up in the shipped extension and are publicly readable.
# Only put values that are safe to be public here.

# Solana mainnet RPC URL. If unset, falls back to the public Solana RPC
# (https://api.mainnet-beta.solana.com), which is heavily rate-limited.
# Recommended: a Helius/QuickNode/Triton URL with a domain-restricted or
# quota-limited key.
#
# When this is a Helius URL, the same endpoint also serves the DAS API
# (`getAssetsByOwner`) used to list SPL tokens on the home screen. No
# separate Helius key is needed.
VITE_RPC_URL=
